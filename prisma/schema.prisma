generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CLINIC
  DOCTOR
}

enum SubscriptionPlan {
  DEMO
  STARTER
  GROWTH
  SCALE
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Clinic {
  id                 String           @id @default(cuid())
  name               String
  slug               String           @unique
  email              String           @unique
  password           String
  address            String?
  phone              String?
  logoPath           String?
  footerText         String?
  isActive           Boolean          @default(true)
  subscriptionPlan   SubscriptionPlan @default(DEMO)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  doctors           Doctor[]
  clinicSettings    ClinicSettings[]
  patients          Patient[]
  medicines         Medicine[]
  prescriptions     Prescription[]
  adviceTemplates    AdviceTemplate[]
}

model Doctor {
  id                     String           @id @default(cuid())
  clinicId               String
  email                  String
  password               String
  name                   String
  qualification          String?
  specialization         String?
  registrationNo         String?
  mobile                 String?
  defaultPrescriptionType PrescriptionType? @default(GENERAL)
  isActive               Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  clinic           Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  clinicSettings   ClinicSettings?
  patients         Patient[]
  medicines        Medicine[]
  prescriptions    Prescription[]
  adviceTemplates  AdviceTemplate[]

  @@unique([clinicId, email])
}

model ClinicSettings {
  id            String   @id @default(cuid())
  doctorId      String   @unique
  clinicId      String
  clinicName    String?
  address       String?
  phone         String?
  logoPath      String?
  signaturePath String?
  stampPath     String?
  footerText    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  doctor        Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic        Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

model Patient {
  id               String   @id @default(cuid())
  clinicId         String
  doctorId         String
  fullName         String
  age              Int?
  dateOfBirth      DateTime?
  gender           Gender
  mobile           String?
  address          String?
  allergies        String?
  chronicConditions String?
  notes            String?
  weight           Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clinic           Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor           Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  prescriptions    Prescription[]
}

model Medicine {
  id               String   @id @default(cuid())
  clinicId         String
  doctorId         String
  name             String
  genericName      String?
  form             MedicineForm @default(TABLET)
  strength         String?
  defaultDosage    String?
  defaultFrequency String?
  defaultDuration  String?
  defaultTiming    MedicineTiming @default(AFTER_FOOD)
  defaultInstructions String?
  isFavorite       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clinic           Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor           Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  prescriptionItems PrescriptionItem[]
}

model Prescription {
  id               String           @id @default(cuid())
  clinicId         String
  doctorId         String
  patientId        String
  status           PrescriptionStatus @default(DRAFT)
  prescriptionType PrescriptionType @default(GENERAL)
  prescriptionDate DateTime         @default(now())
  chiefComplaints  String?
  diagnosis        String?
  clinicalNotes    String?
  investigations   String?
  generalAdvice    String?
  followUpDate     DateTime?
  internalNotes    String?
  templateData     Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  clinic           Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor           Doctor           @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  items            PrescriptionItem[]
}

model PrescriptionItem {
  id              String   @id @default(cuid())
  prescriptionId  String
  medicineId      String?
  medicineName    String
  strength        String?
  dosage          String?
  frequency       String?
  duration        String?
  timing          MedicineTiming?
  route           String?
  instructions    String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  prescription    Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicine        Medicine?    @relation(fields: [medicineId], references: [id], onDelete: SetNull)
}

model AdviceTemplate {
  id        String   @id @default(cuid())
  clinicId  String
  doctorId  String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MedicineForm {
  TABLET
  CAPSULE
  SYRUP
  OINTMENT
  DROPS
  INJECTION
  POWDER
  LOTION
  OTHER
}

enum MedicineTiming {
  BEFORE_FOOD
  AFTER_FOOD
  EMPTY_STOMACH
  ANYTIME
}

enum PrescriptionStatus {
  DRAFT
  FINALIZED
}

enum PrescriptionType {
  GENERAL
  EYE
}
